# infra/.env.example — インフラ操作に必要な環境変数のテンプレート。
# 使い方: このファイルを .env としてコピーし、値を埋めて `source .env`（.env は .gitignore 済み）。
# 秘密情報（アクセスキー等）はここに書かない。認証は `aws configure` / SSO / OIDC を使う。

# デプロイ先アカウント（12桁）。cdk synth では未設定でも可、deploy には必須。
export CDK_DEFAULT_ACCOUNT=123456789012

# リージョン（東京）。
export CDK_DEFAULT_REGION=ap-northeast-1

# 使う AWS プロファイル（任意）。
export AWS_PROFILE=default

# GitHub OIDC ロールの信頼対象リポジトリ（owner/repo）。
# cdk deploy 時に -c githubRepo=$GITHUB_REPO のように渡す。
export GITHUB_REPO=larai-w/social-system-debugger

# 既存の GitHub OIDC プロバイダがある場合のみ設定（重複作成回避）。無ければ空のまま。
# export EXISTING_OIDC_PROVIDER_ARN=arn:aws:iam::123456789012:oidc-provider/token.actions.githubusercontent.com
