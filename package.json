{
  "name": "social-system-debugger",
  "version": "1.0.0",
  "description": "社会デバッガー — educational simulator of how societies break. Web (GitHub Pages / AWS CloudFront) + native (Capacitor iOS/Android).",
  "private": true,
  "scripts": {
    "test": "node --test \"tests/*.test.mjs\"",
    "validate:weekly": "node scripts/validate-weekly.mjs",
    "verify": "node scripts/verify.mjs",
    "verify:offline": "node scripts/verify-offline.mjs",
    "lint": "eslint web/js scripts tests web/config.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm test && npm run validate:weekly && npm run lint && npm run format:check",
    "gen:og": "node scripts/gen-og-image.mjs",
    "gen:shot": "node scripts/gen-screenshot.mjs",
    "gen:classroom-pdf": "node scripts/gen-classroom-pdf.mjs",
    "gen:icons": "node scripts/gen-icons.mjs",
    "record:reels": "node scripts/record-reel.mjs",
    "cap:sync": "cap sync",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "serve": "python3 -m http.server 8000 --directory web"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/larai-w/social-system-debugger.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/larai-w/social-system-debugger/issues"
  },
  "homepage": "https://github.com/larai-w/social-system-debugger#readme",
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@napi-rs/canvas": "^1.0.2",
    "eslint": "^10.6.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4"
  }
}
